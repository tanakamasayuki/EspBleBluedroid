# pytest-embedded derives these names from the Arduino CLI profile names and
# the peer directory name. host/device are fixture names, not BLE roles.
TEST_SERIAL_PORT_ESP32_PEER_HOST=/dev/ttyUSB0
TEST_SERIAL_PORT_PEER_DEVICE_ESP32_PEER_DEVICE=/dev/ttyUSB1

# Optional HTML report:
# PYTEST_ADDOPTS="--html=report.html --self-contained-html"

